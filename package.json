{
  "name": "process-videos",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "process": "tsx src/process.ts",
    "process:cpu": "ENCODE_CPU=1 tsx src/process.ts",
    "upload": "node --env-file=.env --import=tsx src/upload.ts",
    "test": "node --env-file=.env --import=tsx src/test.ts",
    "test:cpu": "ENCODE_CPU=1 node --env-file=.env --import=tsx src/test.ts",
    "all": "node --env-file=.env --import=tsx src/all.ts",
    "all:cpu": "ENCODE_CPU=1 node --env-file=.env --import=tsx src/all.ts",
    "chapters": "node --env-file=.env --import=tsx src/chapters.ts",
    "test:google": "node --env-file=.env --import=tsx src/test-google.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "googleapis": "^146.0.0",
    "log-update": "^7.2.0"
  }
}
